{% extends "base.html" %}

{% block title %}创建餐厅 - 餐厅订餐系统{% endblock %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0 text-center">🏪 创建餐厅</h4>
            </div>
            <div class="card-body p-4">
                <form method="POST" enctype="multipart/form-data" novalidate>
                    {{ form.hidden_tag() }}
                    
                    <!-- 餐厅名称 -->
                    <div class="mb-3">
                        {{ form.name.label(class="form-label") }}
                        {{ form.name(class="form-control" + (" is-invalid" if form.name.errors else "")) }}
                        {% if form.name.errors %}
                            <div class="invalid-feedback">
                                {% for error in form.name.errors %}
                                    {{ error }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                    
                    <!-- Logo上传 -->
                    <div class="mb-3">
                        {{ form.logo.label(class="form-label") }}
                        {{ form.logo(class="form-control" + (" is-invalid" if form.logo.errors else ""), accept="image/jpeg,image/png,image/webp") }}
                        <div class="form-text">
                            支持 jpg、jpeg、png、webp 格式图片
                        </div>
                        {% if form.logo.errors %}
                            <div class="invalid-feedback d-block">
                                {% for error in form.logo.errors %}
                                    {{ error }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                    
                    <!-- 提交按钮 -->
                    <div class="d-grid gap-2">
                        {{ form.submit(class="btn btn-success btn-lg") }}
                    </div>
                </form>
                
                <!-- 返回链接 -->
                <div class="text-center mt-3">
                    <a href="{{ url_for('main.choice') }}" class="text-decoration-none">
                        ← 返回选择页面
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

{% block scripts %}
<script>
// Logo文件验证函数
document.addEventListener('DOMContentLoaded', function() {
    const logoInput = document.getElementById('logo');
    
    if (logoInput) {
        logoInput.addEventListener('change', function(e) {
            if (this.files && this.files[0]) {
                const file = this.files[0];
                
                // 验证文件大小（2MB限制）
                if (file.size > 2 * 1024 * 1024) {
                    alert('Logo文件大小不能超过2MB');
                    this.value = '';
                    return false;
                }
                
                // 验证文件类型
                const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
                if (!allowedTypes.includes(file.type)) {
                    alert('请选择支持的图片格式（jpg、jpeg、png、webp）');
                    this.value = '';
                    return false;
                }
            }
            return true;
        });
    }
});
</script>
{% endblock %}

{% endblock %}
