{% extends "base.html" %}

{% block title %}添加菜品 - {{ category_display }}{% endblock %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0 text-center">
                    🍽️ 添加菜品 - {{ category_display }}
                </h4>
            </div>
            <div class="card-body p-4">
                <form method="POST" enctype="multipart/form-data" novalidate>
                    {{ form.hidden_tag() }}
                    
                    <!-- 菜品名称 -->
                    <div class="mb-3">
                        {{ form.name.label(class="form-label") }}
                        {{ form.name(class="form-control" + (" is-invalid" if form.name.errors else "")) }}
                        {% if form.name.errors %}
                            <div class="invalid-feedback">
                                {% for error in form.name.errors %}
                                    {{ error }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                    
                    <!-- 价格 -->
                    <div class="mb-3">
                        {{ form.price.label(class="form-label") }}
                        <div class="input-group">
                            <span class="input-group-text">¥</span>
                            {{ form.price(class="form-control" + (" is-invalid" if form.price.errors else "")) }}
                            <span class="input-group-text">元</span>
                            {% if form.price.errors %}
                                <div class="invalid-feedback">
                                    {% for error in form.price.errors %}
                                        {{ error }}
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                    
                    <!-- 描述 -->
                    <div class="mb-3">
                        {{ form.description.label(class="form-label") }}
                        {{ form.description(class="form-control" + (" is-invalid" if form.description.errors else "")) }}
                        <div class="form-text">
                            <span id="char-count">0</span>/500 字符
                        </div>
                        {% if form.description.errors %}
                            <div class="invalid-feedback">
                                {% for error in form.description.errors %}
                                    {{ error }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                    
                    <!-- 图片上传 -->
                    <div class="mb-4">
                        {{ form.image.label(class="form-label") }}
                        {{ form.image(class="form-control" + (" is-invalid" if form.image.errors else ""), accept="image/jpeg,image/png,image/webp") }}
                        <div class="form-text">
                            支持 jpg、jpeg、png、webp 格式，图片将自动调整至 100×100 像素以内
                        </div>
                        {% if form.image.errors %}
                            <div class="invalid-feedback d-block">
                                {% for error in form.image.errors %}
                                    {{ error }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                    
                    <!-- 提交按钮 -->
                    <div class="d-grid gap-2">
                        {{ form.submit(class="btn btn-primary btn-lg") }}
                    </div>
                </form>
                
                            <!-- 返回链接 -->
                            <div class="text-center mt-3">
                                <a href="{{ url_for('manager.home') }}" class="text-decoration-none">
                                    ← 返回餐厅管理
                                </a>
                            </div>
                
                <!-- 返回链接 -->
                <div class="text-center mt-3">
                    <a href="{{ url_for('manager.home') }}" class="text-decoration-none">
                        ← 返回餐厅管理
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
    // 字符计数器
    document.addEventListener('DOMContentLoaded', function() {
        var textarea = document.getElementById('description');
        var charCount = document.getElementById('char-count');
        
        if (textarea && charCount) {
            // 初始化计数
            charCount.textContent = textarea.value.length;
            
            // 监听输入事件
            textarea.addEventListener('input', function() {
                charCount.textContent = this.value.length;
                
                // 超过限制时显示红色
                if (this.value.length > 500) {
                    charCount.classList.add('text-danger');
                } else {
                    charCount.classList.remove('text-danger');
                }
            });
        }
        
        // 菜品图片文件验证函数
        const imageInput = document.getElementById('image');
        
        if (imageInput) {
            imageInput.addEventListener('change', function(e) {
                if (this.files && this.files[0]) {
                    const file = this.files[0];
                    
                    // 验证文件大小（2MB限制）
                    if (file.size > 2 * 1024 * 1024) {
                        alert('菜品图片大小不能超过2MB');
                        this.value = '';
                        return false;
                    }
                    
                    // 验证文件类型
                    const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
                    if (!allowedTypes.includes(file.type)) {
                        alert('请选择支持的图片格式（jpg、jpeg、png、webp）');
                        this.value = '';
                        return false;
                    }
                }
                return true;
            });
        }
    });
</script>
{% endblock %}
