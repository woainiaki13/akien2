{% extends "base.html" %}

{% block title %}经营顾问 - {{ restaurant.name }}{% endblock %}

{% block content %}
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-9">
            <div class="card shadow">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">🤖 经营顾问</h4>
                    <div>
                        <a href="{{ url_for('manager.advisor', clear=1) }}" 
                           class="btn btn-sm btn-outline-light"
                           onclick="return confirm('确定要清空聊天记录吗？');">
                            🗑️ 清空记录
                        </a>
                        <a href="{{ url_for('manager.home') }}" class="btn btn-sm btn-outline-light ms-2">
                            ← 返回管理
                        </a>
                    </div>
                </div>
                
                <div class="card-body">
                    <!-- 餐厅信息 -->
                    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                        <img src="{{ url_for('static', filename=restaurant.logo_path) }}" 
                             alt="{{ restaurant.name }}" 
                             class="rounded me-3"
                             style="width: 60px; height: 60px; object-fit: cover;">
                        <div>
                            <h5 class="mb-1">{{ restaurant.name }}</h5>
                            <p class="text-muted small mb-0">智能经营分析顾问为您服务</p>
                        </div>
                    </div>
                    
                    {% if not api_configured %}
                    <!-- API未配置提示 -->
                    <div class="alert alert-warning">
                        <h5 class="alert-heading">⚠️ 智能问答功能未配置</h5>
                        <p class="mb-2">当前未设置 DeepSeek API Key，因此无法使用经营顾问。</p>
                        <hr>
                        <p class="mb-0 small">
                            <strong>配置方法：</strong>设置环境变量 <code>DEEPSEEK_API_KEY</code>（必要），可选配置 <code>DEEPSEEK_BASE_URL</code> / <code>DEEPSEEK_MODEL</code> / <code>DEEPSEEK_TIMEOUT_SECONDS</code>。<br>
                            请联系系统管理员进行配置。
                        </p>
                    </div>

                    <!-- 表单禁用（避免误提交/不崩溃） -->
                    <form class="mt-3">
                        <div class="input-group">
                            <input type="text" class="form-control form-control-lg" placeholder="智能问答功能未配置" disabled>
                            <button type="button" class="btn btn-success btn-lg" disabled>
                                发送 ➤
                            </button>
                        </div>
                    </form>
                    {% else %}
                    
                    <!-- 错误消息 -->
                    {% if error_message %}
                    <div class="alert alert-danger alert-dismissible fade show">
                        {{ error_message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    {% endif %}
                    
                    <!-- 建议问题 -->
                    {% if not chat_history %}
                    <div class="mb-4">
                        <h6 class="text-muted mb-3">💡 试试问这些问题：</h6>
                        <div class="d-flex flex-wrap gap-2">
                            {% for question in suggested_questions %}
                            <button type="button" 
                                    class="btn btn-outline-secondary btn-sm suggested-question"
                                    onclick="document.getElementById('messageInput').value='{{ question }}'; document.getElementById('chatForm').submit();">
                                {{ question }}
                            </button>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                    
                    <!-- 聊天历史 -->
                    <div class="chat-container mb-4" style="max-height: 450px; overflow-y: auto;" id="chatContainer">
                        {% if chat_history %}
                            {% for msg in chat_history %}
                            <div class="mb-3">
                                {% if msg.role == 'user' %}
                                <div class="d-flex justify-content-end">
                                    <div class="bg-success text-white rounded-3 p-3" style="max-width: 80%;">
                                        <small class="d-block text-light opacity-75 mb-1">👤 我</small>
                                        {{ msg.content }}
                                    </div>
                                </div>
                                {% else %}
                                <div class="d-flex justify-content-start">
                                    <div class="bg-light rounded-3 p-3" style="max-width: 85%;">
                                        <small class="d-block text-muted mb-1">🤖 顾问</small>
                                        <div class="advisor-message" style="white-space: pre-wrap;">{{ msg.content }}</div>
                                    </div>
                                </div>
                                {% endif %}
                            </div>
                            {% endfor %}
                        {% else %}
                        <div class="text-center py-4 text-muted">
                            <div class="display-1 mb-2">📊</div>
                            <p>你好！我是您的经营分析顾问。</p>
                            <p class="small">我可以帮您分析：<br>
                                • 哪些客人消费最多<br>
                                • 哪些菜品最畅销<br>
                                • 营业数据统计<br>
                                • 经营建议等
                            </p>
                        </div>
                        {% endif %}
                    </div>
                    
                    <!-- 输入表单 -->
                    <form method="POST" class="mt-3" id="chatForm">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
                        <div class="input-group">
                            <input type="text" 
                                   name="message" 
                                   id="messageInput"
                                   class="form-control form-control-lg" 
                                   placeholder="输入您的问题..."
                                   autocomplete="off"
                                   required>
                            <button type="submit" class="btn btn-success btn-lg">
                                发送 ➤
                            </button>
                        </div>
                    </form>
                    {% endif %}
                    
                    <hr class="my-4">
                    
                    <!-- 功能说明 -->
                    <div class="bg-light rounded p-3">
                        <h6 class="mb-2">📋 功能说明</h6>
                        <ul class="mb-0 small text-muted">
                            <li>经营顾问基于您餐厅的<strong>已支付订单数据</strong>进行分析</li>
                            <li>可以查询消费者排行、菜品销量、销售额等信息</li>
                            <li>提供专业的经营分析和建议</li>
                            <li>聊天记录最多保留最近 10 轮对话</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// 自动滚动到聊天底部
document.addEventListener('DOMContentLoaded', function() {
    var chatContainer = document.getElementById('chatContainer');
    if (chatContainer) {
        chatContainer.scrollTop = chatContainer.scrollHeight;
    }
});
</script>
{% endblock %}
